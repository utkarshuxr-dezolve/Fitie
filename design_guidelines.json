  "layout_patterns": {
    "dashboard": "Bento-style grid for daily overview. Metrics like steps, calories, and active minutes in small square cards, primary workout in a large horizontal card.",
    "scan_machine": "Camera view taking up full screen, with a floating bottom card for detection results (glassmorphism or solid white with heavy border-radius).",
    "lists": "Card-less lists for exercises. Image on left (56x56 rounded-xl), Text in middle, Action icon on right. 1px bottom border separator.",
    "health_insights": "Clean typographic layout. Use primary color (muted green) for AI insights highlights."
  },
  "testing": {
    "data_testid_convention": "kebab-case, role-based. e.g. 'home-tab', 'start-workout-button', 'meal-log-input'"
  },
  "instructions_to_main_agent": [
    "Strictly follow the 8pt spacing grid.",
    "Do not use heavy shadows. Keep the app flat and premium, relying on 1px borders (#E5E7EB) and slight background differences (#FFFFFF vs #F9FAFB) for hierarchy.",
    "Use lucide-react-native for all icons.",
    "For all headings, ensure tracking is tight (letter-spacing: -0.5px) for a premium look.",
    "Ensure all buttons and interactive elements have a testID attribute matching the role.",
    "Use SafeAreaView carefully to handle notches and bottom home indicators properly.",
    "For Bottom Navigation, do not use generic AI-looking glowing icons. Use a pill shape background behind the active icon, colored #EBF3ED, with the icon itself colored #4A7C59."
  ]
}