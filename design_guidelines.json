{
  "theme": "light",
  "archetype": "Hybrid: 1 (Organic & Earthy) + 4 (Swiss & High-Contrast)",
  "brand_name": "Fitie",
  "platform": "React Native Expo",
  "colors": {
    "primary": "#4A7C59",
    "primary_light": "#EBF3ED",
    "background": "#FFFFFF",
    "surface": "#F9FAFB",
    "surface_secondary": "#F3F4F6",
    "border": "#E5E7EB",
    "text_main": "#111827",
    "text_muted": "#6B7280",
    "text_inverse": "#FFFFFF",
    "success": "#059669",
    "warning": "#D97706",
    "error": "#DC2626"
  },
  "typography": {
    "font_family_heading": "Manrope",
    "font_family_body": "Inter",
    "scales": {
      "h1": { "size": 32, "weight": "800", "tracking": -0.5, "line_height": 40 },
      "h2": { "size": 24, "weight": "700", "tracking": -0.5, "line_height": 32 },
      "h3": { "size": 20, "weight": "600", "tracking": -0.2, "line_height": 28 },
      "body": { "size": 16, "weight": "400", "tracking": 0, "line_height": 24 },
      "body_sm": { "size": 14, "weight": "400", "tracking": 0, "line_height": 20 },
      "label": { "size": 12, "weight": "600", "tracking": 0.5, "line_height": 16, "text_transform": "uppercase" }
    }
  },
  "spacing_grid": {
    "base": 8,
    "scale": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24,
      "xl": 32,
      "2xl": 48
    },
    "screen_padding": 24
  },
  "components": {
    "cards": {
      "background": "#F9FAFB",
      "border": "1px solid #E5E7EB",
      "border_radius": 16,
      "padding": 16,
      "shadow": "0px 2px 8px rgba(0,0,0,0.03)"
    },
    "buttons": {
      "primary": {
        "background": "#4A7C59",
        "text_color": "#FFFFFF",
        "border_radius": 12,
        "padding_vertical": 16,
        "padding_horizontal": 24,
        "font_weight": "600"
      },
      "secondary": {
        "background": "#F3F4F6",
        "text_color": "#111827",
        "border_radius": 12,
        "padding_vertical": 16,
        "padding_horizontal": 24,
        "font_weight": "600"
      }
    },
    "bottom_navigation": {
      "background": "#FFFFFF",
      "border_top": "1px solid #E5E7EB",
      "active_icon_color": "#4A7C59",
      "inactive_icon_color": "#9CA3AF",
      "active_indicator_bg": "#EBF3ED",
      "padding_bottom": "env(safe-area-inset-bottom)"
    },
    "inputs": {
      "background": "#F9FAFB",
      "border": "1px solid #E5E7EB",
      "border_radius": 12,
      "padding": 16,
      "focus_border": "#4A7C59"
    }
  },
  "icons": {
    "library": "lucide-react-native",
    "stroke_width": 2,
    "sizes": {
      "sm": 16,
      "md": 24,
      "lg": 32
    }
  },
